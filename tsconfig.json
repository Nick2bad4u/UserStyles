{
	"$schema": "https://www.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"allowArbitraryExtensions": false,
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"allowUmdGlobalAccess": false,
		"allowUnreachableCode": false,
		"allowUnusedLabels": false,
		"alwaysStrict": true,
		"assumeChangesOnlyAffectDirectDependencies": true,
		"checkJs": false,
		"declaration": false,
		"declarationMap": false,
		"diagnostics": false,
		"disableReferencedProjectLoad": false,
		"disableSizeLimit": true,
		"disableSolutionSearching": false,
		"disableSourceOfProjectReferenceRedirect": false,
		"emitBOM": false,
		"emitDecoratorMetadata": false,
		"erasableSyntaxOnly": true,
		"esModuleInterop": true,
		"exactOptionalPropertyTypes": true,
		"experimentalDecorators": false,
		"explainFiles": false,
		"extendedDiagnostics": false,
		"forceConsistentCasingInFileNames": true,
		"importHelpers": true,
		"incremental": true,
		"inlineSourceMap": false,
		"inlineSources": false,
		"isolatedDeclarations": false,
		"isolatedModules": false,
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"listEmittedFiles": false,
		"listFiles": false,
		"module": "ESNext",
		"moduleDetection": "auto",
		"moduleResolution": "Bundler",
		"newLine": "crlf",
		"noCheck": false,
		"noEmit": true,
		"noEmitHelpers": false,
		"noEmitOnError": true,
		"noErrorTruncation": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"noImplicitUseStrict": false,
		"noLib": false,
		"noPropertyAccessFromIndexSignature": true,
		"noResolve": false,
		"noUncheckedIndexedAccess": true,
		"noUncheckedSideEffectImports": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"preserveConstEnums": true,
		"preserveSymlinks": false,
		"preserveWatchOutput": false,
		"pretty": true,
		"removeComments": false,
		"resolveJsonModule": true,
		"resolvePackageJsonExports": true,
		"resolvePackageJsonImports": true,
		"rewriteRelativeImportExtensions": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"strictBindCallApply": true,
		"strictBuiltinIteratorReturn": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"strictPropertyInitialization": true,
		"stripInternal": false,
		"target": "ES2024",
		"traceResolution": false,
		"tsBuildInfoFile": ".cache/tsbuildinfo/tsconfig.tsbuildinfo",
		"types": ["node"],
		"useDefineForClassFields": true,
		"useUnknownInCatchVariables": true,
		"verbatimModuleSyntax": false
	},
	"include": ["**/*.js", "**/*.mjs", "**/*.cjs", "**/*.ts"],
	"exclude": [
		".cache/**",
		"node_modules/**",
		"dist/**",
		"build/**",
		"**/*.min.js",
		"strava-balance/buffer-5.6.1/**",
		"beautify-css-mod.js",
		"beautify.js",
		"css.js",
		"codemirror.js",
		"codemirror.min.js",
		"strava-balance/binary.js",
		"strava-balance/Strava-AddBalance.js",
		"SuperchargedLocalDirectoryWebUI.user.js"
	],
	"typeAcquisition": {
		"enable": true,
		"exclude": [],
		"include": []
	},
	"watchOptions": {
		"excludeDirectories": [
			"**/node_modules",
			".cache",
			".coverage",
			".git",
			".husky",
			".vscode",
			"_build",
			"dist/*",
			"out/*",
			"release/*",
			"temp/*"
		],
		"excludeFiles": [],
		"fallbackPolling": "dynamicPriority",
		"synchronousWatchDirectory": true,
		"watchDirectory": "useFsEvents",
		"watchFile": "useFsEvents"
	}
}
