    "lint:attw": "node scripts/check-package-types.mjs",
    "lint:config-effective": "node scripts/inspect-effective-config.mjs",
    "lint:config-plugin-usage": "node scripts/check-unused-config-plugins.mjs",
    "lint:config-rule-counts": "node scripts/count-rules-by-plugin.mjs",
    "lint:css": "stylelint \"**/*.user.css\" --cache --cache-strategy content --cache-location .cache/stylelintcache",
    "lint:css:fix": "npm run lint:css -- --fix",
    "lint:fix": "npm run lint -- --fix",
    "lint:nocache": "cross-env NODE_OPTIONS=--max_old_space_size=8192 eslint . --no-cache",
    "lint:package": "npm run lint:package-sort && npm run lint:package-json && npm run lint:package-check",
    "lint:package:fix": "sort-package-json package.json",
    "lint:package:strict": "npm run package:check && npm run lint:publint && npm run lint:attw && npm run lint:package-json && npm run lint:package-sort",
    "lint:package-check": "npm run package:check",
    "lint:package-fix": "npm run lint:package:fix",
    "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
    "lint:package-sort": "sort-package-json --check package.json",
    "lint:prettier": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
    "lint:prettier:fix": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
    "lint:publint": "publint",
    "lint:secretlint": "secretlint --secretlintrc .secretlintrc.cjs --secretlintignore .gitignore \"**/*\"",
    "lint:yaml": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache \"**/*.{yml,yaml}\"",
    "lint:yaml:fix": "npm run lint:yaml -- --fix",
    "package:check": "npm pack --dry-run --json",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:watch": "jest --config jest.config.cjs --watch",
    "types:update": "typesync",
    "update-actions": "npx actions-up --yes --style sha",
    "update-deps": "npx ncu -i --install never && npm update --force && npm install --force",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./",
    "lint:jscpd": "jscpd --config node_modules/jscpd-config-nick2bad4u/jscpd.json",
    "lint:lychee": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml .",
    "lint:lychee:smoke": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml --dump-inputs README.md"
  },
